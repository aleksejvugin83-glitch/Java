        super(recordBookNumber, lastName, firstName, group, department, 
              discipline, grade, teacherLastName);
        this.targetEnterprise = targetEnterprise;
        this.tuitionFee = tuitionFee;
    }
    
    @Override
    public void printInfo() {
        super.printInfo();
        System.out.println("Тип: Целевое обучение");
        System.out.println("Целевое предприятие: " + targetEnterprise);
        System.out.println("Сумма обучения: " + tuitionFee + " руб.");
        System.out.println("------------------------");
    }
}

// Класс для хранения списка студентов
class StudentList {
    private List<Student> students;
    
    public StudentList() {
        students = new ArrayList<>();
    }
    
    // Метод добавления нового студента
    public void addStudent(Student student) {
        students.add(student);
        System.out.println("Студент добавлен в список!");
    }
    
    // Метод печати списка студентов
    public void printAllStudents() {
        if (students.isEmpty()) {
            System.out.println("Список студентов пуст.");
            return;
        }
        
        System.out.println("\n========== СПИСОК СТУДЕНТОВ ==========");
        for (int i = 0; i < students.size(); i++) {
            System.out.println("Студент #" + (i + 1));
            students.get(i).printInfo();
        }
    }
    
    // Дополнительный метод: получение количества студентов
    public int getStudentCount() {
        return students.size();
    }
}

