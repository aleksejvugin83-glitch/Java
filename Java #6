public class Main {
    public static void main(String[] args) {
        // Проверяем, что передано достаточно аргументов
        if (args.length < 2) {
            System.out.println("Ошибка: необходимо передать два числа в качестве аргументов.");
            System.out.println("Пример использования: java Main 5 25");
            return;
        }
        
        try {
            // Парсим аргументы в числа
            double x = Double.parseDouble(args[0]);
            double y = Double.parseDouble(args[1]);
            
            // Вычисляем произведение
            double product = x * y;
            
            // Проверяем условие
            if (product > 100) {
                // Вычисляем удвоенный куб первого числа
                double result = 2 * Math.pow(x, 3);
                System.out.println("Произведение " + x + " * " + y + " = " + product + " > 100");
                System.out.println("Удвоенный куб первого числа: " + result);
            } else {
                System.out.println("Произведение " + x + " * " + y + " = " + product + " <= 100");
                System.out.println("Условие не выполняется, результат не вычисляется.");
            }
            
        } catch (NumberFormatException e) {
            System.out.println("Ошибка: оба аргумента должны быть числами.");
        }
    }
}
