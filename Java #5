import java.util.ArrayList;
import java.util.List;

// Родительский класс Студент
class Student {
    protected String recordBookNumber;
    protected String lastName;
    protected String firstName;
    protected String group;
    protected String department;
    protected String discipline;
    protected int grade;
    protected String teacherLastName;
    
    public Student(String recordBookNumber, String lastName, String firstName, 
                   String group, String department, String discipline, 
                   int grade, String teacherLastName) {
        this.recordBookNumber = recordBookNumber;
        this.lastName = lastName;
        this.firstName = firstName;
        this.group = group;
        this.department = department;
        this.discipline = discipline;
        this.grade = grade;
        this.teacherLastName = teacherLastName;
    }
    
    public void printInfo() {
        System.out.println("Зачетка: " + recordBookNumber);
        System.out.println("ФИО: " + lastName + " " + firstName);
        System.out.println("Группа: " + group);
        System.out.println("Кафедра: " + department);
        System.out.println("Дисциплина: " + discipline);
        System.out.println("Оценка: " + grade);
        System.out.println("Преподаватель: " + teacherLastName);
    }
}

// Дочерний класс Очное отделение
class FullTimeStudent extends Student {
    private int egeScore;
    private double averageCertificateScore;
    
    public FullTimeStudent(String recordBookNumber, String lastName, String firstName, 
                          String group, String department, String discipline, 
                          int grade, String teacherLastName, 
                          int egeScore, double averageCertificateScore) {
        super(recordBookNumber, lastName, firstName, group, department, 
              discipline, grade, teacherLastName);
        this.egeScore = egeScore;
        this.averageCertificateScore = averageCertificateScore;
    }
    
    @Override
    public void printInfo() {
        super.printInfo();
        System.out.println("Тип: Очное отделение");
        System.out.println("Балл ЕГЭ: " + egeScore);
        System.out.println("Средний балл аттестата: " + averageCertificateScore);
        System.out.println("------------------------");
    }
}

// Дочерний класс Заочное отделение
class PartTimeStudent extends Student {
    private String workplace;
    private String position;
    private double tuitionFee;
    
    public PartTimeStudent(String recordBookNumber, String lastName, String firstName, 
                          String group, String department, String discipline, 
                          int grade, String teacherLastName, 
                          String workplace, String position, double tuitionFee) {
        super(recordBookNumber, lastName, firstName, group, department, 
              discipline, grade, teacherLastName);
        this.workplace = workplace;
        this.position = position;
        this.tuitionFee = tuitionFee;
    }
    
    @Override
    public void printInfo() {
        super.printInfo();
        System.out.println("Тип: Заочное отделение");
        System.out.println("Место работы: " + workplace);
        System.out.println("Должность: " + position);
        System.out.println("Сумма обучения: " + tuitionFee + " руб.");
        System.out.println("------------------------");
    }
}

// Дочерний класс Целевое обучение
class TargetedStudent extends Student {
